{
  "name": "marco-trevisani",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=24",
    "bun": ">=1.3.13"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "postcss": "8.5.10"
  },
  "scripts": {
    "dev": "bun run --cwd apps/site dev",
    "build": "bun run --cwd packages/alien-ui build && bun run --cwd apps/site build",
    "start": "bun run --cwd apps/site start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --build --pretty false",
    "lint": "biome check .",
    "format": "biome check --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "husky": "9.1.7",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
